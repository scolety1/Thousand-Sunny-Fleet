{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Fleet Thin Task Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packetId",
    "taskId",
    "mode",
    "goal",
    "stableContextCapsuleRef",
    "phase0Gate",
    "allowedFiles",
    "readFirst",
    "acceptance",
    "validationCommands",
    "stopIf",
    "statusUpdateRules",
    "evidenceDigest"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "packetId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "taskId": {
      "type": "string",
      "pattern": "^HQ-[0-9]{3}$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "validation_only",
        "docs_only",
        "schema_fixture_test",
        "docs_and_tests",
        "audit_package_planning",
        "queue_bookkeeping_only"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 12,
      "maxLength": 500
    },
    "stableContextCapsuleRef": {
      "type": "string",
      "const": "docs/fleet/STABLE_CONTEXT_CAPSULE.md"
    },
    "phase0Gate": {
      "$ref": "#/$defs/phase0Gate"
    },
    "allowedFiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/localPath"
      }
    },
    "readFirst": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/localPath"
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "validationCommands": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300,
        "not": {
          "pattern": "(?i)(git\\s+(add|commit|merge|push|reset|checkout)|npm\\s+install|pnpm\\s+install|yarn\\s+install|deploy|migration|secrets?|auth|payments?|token|credential|private[-_]?key|run-fleet\\.ps1|launch-|start-overnight-autopilot|fleet-supervisor|fleet-remote-control|all-fleet)"
        }
      }
    },
    "stopIf": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "statusUpdateRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "onValidationPass",
        "onValidationFail",
        "onScopeExpansion",
        "queueFile",
        "oneTaskOnly"
      ],
      "properties": {
        "onValidationPass": {
          "type": "string",
          "const": "mark_this_task_done"
        },
        "onValidationFail": {
          "type": "string",
          "const": "patch_only_task_caused_failures_or_mark_blocked"
        },
        "onScopeExpansion": {
          "type": "string",
          "const": "mark_this_task_blocked_and_stop"
        },
        "queueFile": {
          "type": "string",
          "const": "docs/fleet/HQ_REPAIR_TASK_QUEUE.md"
        },
        "oneTaskOnly": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "evidenceDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceRefs",
        "nonAuthorityNotice",
        "expectedEvidence"
      ],
      "properties": {
        "sourceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localPath"
          },
          "uniqueItems": true
        },
        "nonAuthorityNotice": {
          "type": "string",
          "minLength": 12,
          "maxLength": 500
        },
        "expectedEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    }
  },
  "$defs": {
    "phase0Gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "laneScopeDeclaration",
        "existingAssetTrace",
        "reuseDecision",
        "buildPermission",
        "scopeExpansionRule"
      ],
      "properties": {
        "laneScopeDeclaration": {
          "$ref": "#/$defs/laneScopeDeclaration"
        },
        "existingAssetTrace": {
          "$ref": "#/$defs/existingAssetTrace"
        },
        "reuseDecision": {
          "$ref": "#/$defs/reuseDecision"
        },
        "buildPermission": {
          "$ref": "#/$defs/buildPermission"
        },
        "scopeExpansionRule": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500,
          "pattern": "TIM_REQUIRED_SCOPE_EXPANSION"
        }
      }
    },
    "laneScopeDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "laneType",
        "allowedSearchScope",
        "forbiddenSearchScope",
        "canonicalRepoInspectionAllowed",
        "normalNwrPacketReadsAllowed",
        "crossLaneComparisonAllowed",
        "mutationAllowed",
        "timApprovalRequiredForScopeExpansion"
      ],
      "properties": {
        "laneType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "allowedSearchScope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        },
        "forbiddenSearchScope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        },
        "canonicalRepoInspectionAllowed": {
          "type": "boolean"
        },
        "normalNwrPacketReadsAllowed": {
          "type": "boolean"
        },
        "crossLaneComparisonAllowed": {
          "type": "boolean"
        },
        "mutationAllowed": {
          "type": "boolean"
        },
        "timApprovalRequiredForScopeExpansion": {
          "type": "boolean"
        }
      }
    },
    "existingAssetTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "searchedLocations",
        "matchingFilesOrFolders",
        "relevantExistingArtifacts",
        "classification",
        "reuseDecision",
        "whyNewBuildIsOrIsNotAllowed",
        "restrictedScopeExclusions"
      ],
      "properties": {
        "searchedLocations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        },
        "matchingFilesOrFolders": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        },
        "relevantExistingArtifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "classification": {
          "$ref": "#/$defs/assetClassification"
        },
        "reuseDecision": {
          "$ref": "#/$defs/reuseDecision"
        },
        "whyNewBuildIsOrIsNotAllowed": {
          "type": "string",
          "minLength": 12,
          "maxLength": 1000
        },
        "restrictedScopeExclusions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    },
    "buildPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "newBuildAllowed",
        "whyNewBuildIsOrIsNotAllowed"
      ],
      "properties": {
        "newBuildAllowed": {
          "type": "boolean"
        },
        "whyNewBuildIsOrIsNotAllowed": {
          "type": "string",
          "minLength": 12,
          "maxLength": 1000
        }
      }
    },
    "assetClassification": {
      "type": "string",
      "enum": [
        "already_exists_admitted",
        "exists_display_only",
        "exists_review_only",
        "exists_not_joined",
        "exists_wrong_scope",
        "exists_stale",
        "exists_conflicting",
        "exists_duplicate",
        "not_found"
      ]
    },
    "reuseDecision": {
      "type": "string",
      "enum": [
        "REUSE",
        "ADMIT_OR_GATE",
        "ADAPTER_NEEDED",
        "NULL_FENCE_NEEDED",
        "VALIDATION_NEEDED",
        "NEW_BUILD_ALLOWED",
        "STOP"
      ]
    },
    "localPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "not": {
        "pattern": "(?i)(^[A-Za-z]:|^/|(^|[\\\\/])\\.\\.([\\\\/]|$)|(^|[\\\\/])(\\.git|\\.env|node_modules|dist|build|secrets?|auth|payments?|deploy|migrations?)([\\\\/]|$)|secret|token|credential|private[-_]?key|[\\u0000-\\u001F\\u007F-\\u009F]|\\u2215|\\u2044|\\uFF0F|\\uFF3C|\\u2216|^\\s|\\s$)"
      }
    }
  }
}
