{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Fleet Entrypoint Safety Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "entrypoints", "validatorExpectations"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "class",
          "riskLevel",
          "canReadProductRepos",
          "canMutateProductRepos",
          "requires",
          "canLaunchChildWorkers",
          "writesAuditOrEvidenceOnly",
          "forbiddenUnattended",
          "forbiddenWhileRateLimited",
          "humanApprovalRequired",
          "notes"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^:*?\"<>|]+\\.ps1$"
          },
          "class": {
            "type": "string",
            "enum": [
              "read_only_status",
              "fixture_only",
              "selected_ship_required",
              "selected_project_required",
              "external_review_request_only",
              "mobile_request_only",
              "legacy_broad_requires_human"
            ]
          },
          "riskLevel": {
            "type": "string",
            "enum": ["low", "medium", "high", "legacy-broad"]
          },
          "canReadProductRepos": {
            "type": "boolean"
          },
          "canMutateProductRepos": {
            "type": "boolean"
          },
          "requires": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ship": {
                "type": "boolean"
              },
              "project": {
                "type": "boolean"
              },
              "preset": {
                "type": "boolean"
              },
              "packetValidation": {
                "type": "boolean"
              },
              "sanitizedInput": {
                "type": "boolean"
              },
              "humanApproval": {
                "type": "boolean"
              }
            }
          },
          "canLaunchChildWorkers": {
            "type": "boolean"
          },
          "writesAuditOrEvidenceOnly": {
            "type": "boolean"
          },
          "forbiddenUnattended": {
            "type": "boolean"
          },
          "forbiddenWhileRateLimited": {
            "type": "boolean"
          },
          "humanApprovalRequired": {
            "type": "boolean"
          },
          "notes": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    },
    "validatorExpectations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "categories",
        "highRiskEntrypoints",
        "defaultAutonomyAllowed",
        "requiresExactHumanApproval",
        "nonExecutableInputs"
      ],
      "properties": {
        "categories": {
          "type": "array",
          "minItems": 7,
          "items": {
            "type": "string",
            "enum": [
              "read_only_status",
              "fixture_only",
              "selected_ship_required",
              "selected_project_required",
              "external_review_request_only",
              "mobile_request_only",
              "legacy_broad_requires_human"
            ]
          },
          "uniqueItems": true
        },
        "highRiskEntrypoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^:*?\"<>|]+\\.ps1$"
          },
          "uniqueItems": true
        },
        "defaultAutonomyAllowed": {
          "type": "boolean",
          "const": false
        },
        "requiresExactHumanApproval": {
          "type": "boolean",
          "const": true
        },
        "nonExecutableInputs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "external_reports",
              "mobile_requests",
              "task_packets",
              "audit_packages",
              "docx_reports",
              "queue_prose"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
