{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Fleet Task Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["packetId", "generatedAt", "project", "baseCommit", "phase0Gate", "tasks"],
  "properties": {
    "packetId": { "type": "string", "minLength": 8, "maxLength": 80, "pattern": "^[A-Za-z0-9._:-]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "project": {
      "type": "string",
      "maxLength": 80,
      "minLength": 1,
      "not": { "pattern": "(?i)^(all|\\*|.*,.*)$|[\\u0000-\\u001F\\u007F-\\u009F]|\\u2215|\\u2044|\\uFF0F|\\uFF3C|\\u2216|^\\s|\\s$" }
    },
    "baseCommit": { "type": "string", "minLength": 1 },
    "phase": { "type": "string", "minLength": 1 },
    "phase0Gate": { "$ref": "#/$defs/phase0Gate" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "checklistLine"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 80, "pattern": "^[A-Za-z0-9._:-]+$" },
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "checklistLine": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1,
            "not": {
              "pattern": "(?i)(^[A-Za-z]:|^/|(^|[\\\\/])\\.\\.([\\\\/]|$)|(^|[\\\\/])(\\.git|\\.env|node_modules|dist|build|secrets?|auth|payments?|deploy|migrations?)([\\\\/]|$)|secret|token|credential|private[-_]?key|[\\u0000-\\u001F\\u007F-\\u009F]|\\u2215|\\u2044|\\uFF0F|\\uFF3C|\\u2216|^\\s|\\s$)"
            }
          },
          "notes": {
            "type": "string",
            "maxLength": 500,
            "not": {
              "pattern": "(?i)(^[A-Za-z]:|^/|(^|[\\\\/])\\.\\.([\\\\/]|$)|(^|[\\\\/])(\\.git|\\.env|node_modules|dist|build|secrets?|auth|payments?|deploy|migrations?)([\\\\/]|$)|secret|token|credential|private[-_]?key|[\\u0000-\\u001F\\u007F-\\u009F]|\\u2215|\\u2044|\\uFF0F|\\uFF3C|\\u2216|^\\s|\\s$)"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "phase0Gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["laneScopeDeclaration", "existingAssetTrace", "reuseDecision", "buildPermission", "scopeExpansionRule"],
      "properties": {
        "laneScopeDeclaration": { "$ref": "#/$defs/laneScopeDeclaration" },
        "existingAssetTrace": { "$ref": "#/$defs/existingAssetTrace" },
        "reuseDecision": { "$ref": "#/$defs/reuseDecision" },
        "buildPermission": { "$ref": "#/$defs/buildPermission" },
        "scopeExpansionRule": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500,
          "pattern": "TIM_REQUIRED_SCOPE_EXPANSION"
        }
      }
    },
    "laneScopeDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "laneType",
        "allowedSearchScope",
        "forbiddenSearchScope",
        "canonicalRepoInspectionAllowed",
        "normalNwrPacketReadsAllowed",
        "crossLaneComparisonAllowed",
        "mutationAllowed",
        "timApprovalRequiredForScopeExpansion"
      ],
      "properties": {
        "laneType": { "type": "string", "minLength": 1, "maxLength": 160 },
        "allowedSearchScope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "forbiddenSearchScope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "canonicalRepoInspectionAllowed": { "type": "boolean" },
        "normalNwrPacketReadsAllowed": { "type": "boolean" },
        "crossLaneComparisonAllowed": { "type": "boolean" },
        "mutationAllowed": { "type": "boolean" },
        "timApprovalRequiredForScopeExpansion": { "type": "boolean" }
      }
    },
    "existingAssetTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "searchedLocations",
        "matchingFilesOrFolders",
        "relevantExistingArtifacts",
        "classification",
        "reuseDecision",
        "whyNewBuildIsOrIsNotAllowed",
        "restrictedScopeExclusions"
      ],
      "properties": {
        "searchedLocations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "matchingFilesOrFolders": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "relevantExistingArtifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "classification": { "$ref": "#/$defs/assetClassification" },
        "reuseDecision": { "$ref": "#/$defs/reuseDecision" },
        "whyNewBuildIsOrIsNotAllowed": { "type": "string", "minLength": 12, "maxLength": 1000 },
        "restrictedScopeExclusions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "buildPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["newBuildAllowed", "whyNewBuildIsOrIsNotAllowed"],
      "properties": {
        "newBuildAllowed": { "type": "boolean" },
        "whyNewBuildIsOrIsNotAllowed": { "type": "string", "minLength": 12, "maxLength": 1000 }
      }
    },
    "assetClassification": {
      "type": "string",
      "enum": [
        "already_exists_admitted",
        "exists_display_only",
        "exists_review_only",
        "exists_not_joined",
        "exists_wrong_scope",
        "exists_stale",
        "exists_conflicting",
        "exists_duplicate",
        "not_found"
      ]
    },
    "reuseDecision": {
      "type": "string",
      "enum": [
        "REUSE",
        "ADMIT_OR_GATE",
        "ADAPTER_NEEDED",
        "NULL_FENCE_NEEDED",
        "VALIDATION_NEEDED",
        "NEW_BUILD_ALLOWED",
        "STOP"
      ]
    }
  }
}
