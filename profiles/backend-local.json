{
  "name": "backend-local",
  "description": "Profile for local-only backend work with fake data, API contract tests, and no production services.",
  "projectType": "full-stack-web",
  "riskTier": "local-only",
  "capabilities": {
    "canEditPackageFiles": false,
    "canAddDependencies": false,
    "canEditBackendCode": true,
    "canEditMigrations": false,
    "canEditAuthPolicy": false,
    "canEditDeploymentConfig": false,
    "canUseNetworkApis": false,
    "canOpenPullRequests": false,
    "canDeploy": false
  },
  "defaultRounds": 6,
  "branchPrefix": "codex/backend-local",
  "maxChangedFiles": 10,
  "maxBatchChangedFiles": 8,
  "model": "gpt-5.5",
  "models": {
    "implement": ["gpt-5.5", "gpt-5.3-codex", "gpt-5.4"],
    "review": ["gpt-5.5", "gpt-5.4"],
    "planner": ["gpt-5.5", "gpt-5.4"],
    "checkpoint": ["gpt-5.5", "gpt-5.4"],
    "simon": ["gpt-5.5", "gpt-5.4"]
  },
  "timeouts": {
    "codex": 1800,
    "implement": 1800,
    "review": 1200,
    "build": 900,
    "planner": 600,
    "checkpoint": 600,
    "simon": 600,
    "visual": 600,
    "joey": 300,
    "debug": 300,
    "guardrails": 180,
    "rateLimitCooldownSeconds": 3600,
    "rateLimitMaxCooldowns": 4
  },
  "allowedPaths": [
    "src/",
    "server/",
    "api/",
    "backend/",
    "tests/",
    "sample_data/",
    "fixtures/",
    "docs/codex/",
    "README.md"
  ],
  "blockedPaths": [
    ".env",
    ".env.local",
    ".env.production",
    "dist/",
    "build/",
    "firebase.json",
    "firestore.rules",
    ".firebaserc"
  ],
  "blockedTerms": [
    "api key",
    "bearer token",
    "secret",
    "production database",
    "real customer data",
    "stripe",
    "payment"
  ],
  "buildDirectory": ".",
  "buildCommand": ""
}
