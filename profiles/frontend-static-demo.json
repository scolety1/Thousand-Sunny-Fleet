{
  "name": "frontend-static-demo",
  "description": "Moderate profile for static frontend demo and sales-site repositories.",
  "defaultRounds": 12,
  "branchPrefix": "codex/static-demo",
  "maxChangedFiles": 16,
  "model": "gpt-5.5",
  "models": {
    "implement": ["gpt-5.5", "gpt-5.3-codex", "gpt-5.4"],
    "review": ["gpt-5.5", "gpt-5.4"],
    "planner": ["gpt-5.5", "gpt-5.4"],
    "checkpoint": ["gpt-5.5", "gpt-5.4"],
    "simon": ["gpt-5.5", "gpt-5.4"]
  },
  "timeouts": {
    "codex": 1800,
    "implement": 1800,
    "review": 1200,
    "build": 600,
    "planner": 600,
    "checkpoint": 600,
    "simon": 600,
    "visual": 900,
    "joey": 300,
    "debug": 300,
    "guardrails": 180
  },
  "visualPaths": [
    "/"
  ],
  "allowedPaths": [
    "src/",
    "docs/codex/",
    "README.md",
    ".gitattributes",
    ".gitignore"
  ],
  "blockedPaths": [
    "dist/",
    "build/",
    "server/",
    "api/",
    "functions/",
    "backend/",
    ".env",
    "package.json",
    "package-lock.json",
    "npm-shrinkwrap.json"
  ],
  "blockedTerms": [
    "backend",
    "auth",
    "login",
    "oauth",
    "stripe",
    "payment",
    "checkout",
    "firebase",
    "supabase",
    "api key",
    "secret",
    "analytics",
    "tracking",
    "gtag",
    "pixel",
    "hotjar"
  ],
  "buildDirectory": ".",
  "buildCommand": "npm.cmd run build"
}
