{
  "name": "frontend-static-demo",
  "description": "Moderate profile for static frontend demo and sales-site repositories.",
  "defaultRounds": 12,
  "branchPrefix": "codex/static-demo",
  "maxChangedFiles": 16,
  "model": "gpt-5.5",
  "models": {
    "implement": "gpt-5.5",
    "review": "gpt-5.5",
    "planner": "gpt-5.5",
    "checkpoint": "gpt-5.5",
    "simon": "gpt-5.5"
  },
  "visualPaths": [
    "/"
  ],
  "allowedPaths": [
    "src/",
    "docs/codex/",
    "README.md",
    ".gitattributes",
    ".gitignore"
  ],
  "blockedPaths": [
    "dist/",
    "build/",
    "server/",
    "api/",
    "functions/",
    "backend/",
    ".env",
    "package.json",
    "package-lock.json",
    "npm-shrinkwrap.json"
  ],
  "blockedTerms": [
    "backend",
    "auth",
    "login",
    "oauth",
    "stripe",
    "payment",
    "checkout",
    "firebase",
    "supabase",
    "api key",
    "secret",
    "analytics",
    "tracking",
    "gtag",
    "pixel",
    "hotjar"
  ],
  "buildDirectory": ".",
  "buildCommand": "npm.cmd run build"
}
