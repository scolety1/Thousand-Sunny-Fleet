{
  "name": "docs-only",
  "description": "Profile for documentation-only repositories or documentation-only passes.",
  "defaultRounds": 10,
  "branchPrefix": "codex/docs",
  "maxChangedFiles": 12,
  "model": "gpt-5.5",
  "models": {
    "implement": "gpt-5.5",
    "review": "gpt-5.5",
    "planner": "gpt-5.5",
    "checkpoint": "gpt-5.5",
    "simon": "gpt-5.5"
  },
  "allowedPaths": [
    "docs/",
    "README.md"
  ],
  "blockedPaths": [
    ".env",
    "package.json",
    "package-lock.json",
    "functions/",
    "src/",
    "app-vNext/src/"
  ],
  "blockedTerms": [
    "api key",
    "secret",
    "credential"
  ],
  "buildDirectory": ".",
  "buildCommand": ""
}
