{
  "name": "experimental-prototype",
  "description": "Profile for sandboxed prototypes with fake data and no real integrations.",
  "defaultRounds": 8,
  "branchPrefix": "codex/experiment",
  "maxChangedFiles": 14,
  "model": "gpt-5.5",
  "models": {
    "implement": ["gpt-5.5", "gpt-5.3-codex", "gpt-5.4"],
    "review": ["gpt-5.5", "gpt-5.4"],
    "planner": ["gpt-5.5", "gpt-5.4"],
    "checkpoint": ["gpt-5.5", "gpt-5.4"],
    "simon": ["gpt-5.5", "gpt-5.4"]
  },
  "timeouts": {
    "codex": 1500,
    "implement": 1500,
    "review": 900,
    "build": 600,
    "planner": 600,
    "checkpoint": 600,
    "simon": 600,
    "visual": 900,
    "joey": 300,
    "debug": 300,
    "guardrails": 180
  },
  "visualPaths": [
    "/"
  ],
  "allowedPaths": [
    "src/",
    "app-vNext/src/features/experiments/",
    "docs/codex/",
    "docs/ai/",
    "README.md"
  ],
  "blockedPaths": [
    ".env",
    "functions/",
    "server/",
    "api/",
    "backend/",
    "package.json",
    "package-lock.json",
    "npm-shrinkwrap.json"
  ],
  "blockedTerms": [
    "api key",
    "bearer token",
    "secret",
    "real api",
    "openai key",
    "firebase functions",
    "stripe",
    "payment",
    "auth provider"
  ],
  "buildDirectory": ".",
  "buildCommand": "npm.cmd run build"
}
