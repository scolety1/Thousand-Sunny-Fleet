{
  "name": "experimental-prototype",
  "description": "Profile for sandboxed prototypes with fake data and no real integrations.",
  "defaultRounds": 8,
  "branchPrefix": "codex/experiment",
  "maxChangedFiles": 14,
  "model": "gpt-5.5",
  "models": {
    "implement": "gpt-5.5",
    "review": "gpt-5.5",
    "planner": "gpt-5.5",
    "checkpoint": "gpt-5.5",
    "simon": "gpt-5.5"
  },
  "visualPaths": [
    "/"
  ],
  "allowedPaths": [
    "src/",
    "app-vNext/src/features/experiments/",
    "docs/codex/",
    "docs/ai/",
    "README.md"
  ],
  "blockedPaths": [
    ".env",
    "functions/",
    "server/",
    "api/",
    "backend/",
    "package.json",
    "package-lock.json",
    "npm-shrinkwrap.json"
  ],
  "blockedTerms": [
    "api key",
    "bearer token",
    "secret",
    "real api",
    "openai key",
    "firebase functions",
    "stripe",
    "payment",
    "auth provider"
  ],
  "buildDirectory": ".",
  "buildCommand": "npm.cmd run build"
}
