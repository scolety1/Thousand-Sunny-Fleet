{
  "name": "real-product",
  "description": "Strict profile for real product repositories.",
  "defaultRounds": 6,
  "branchPrefix": "codex/product",
  "maxChangedFiles": 8,
  "model": "gpt-5.5",
  "models": {
    "implement": ["gpt-5.5", "gpt-5.3-codex", "gpt-5.4"],
    "review": ["gpt-5.5", "gpt-5.4"],
    "planner": ["gpt-5.5", "gpt-5.4"],
    "checkpoint": ["gpt-5.5", "gpt-5.4"],
    "simon": ["gpt-5.5", "gpt-5.4"]
  },
  "timeouts": {
    "codex": 2400,
    "implement": 2400,
    "review": 1500,
    "build": 900,
    "planner": 900,
    "checkpoint": 900,
    "simon": 900,
    "visual": 900,
    "joey": 300,
    "debug": 300,
    "guardrails": 180,
    "rateLimitCooldownSeconds": 3600,
    "rateLimitMaxCooldowns": 6
  },
  "visualPaths": [
    "/"
  ],
  "allowedPaths": [
    "app-vNext/src/",
    "docs/codex/",
    "docs/ai/",
    "README.md"
  ],
  "blockedPaths": [
    ".firebaserc",
    "firebase.json",
    "firestore.rules",
    "functions/",
    "old-site/",
    "dist/",
    "build/",
    "app-vNext/dist/",
    "app-vNext/build/",
    "app-vNext/coverage/",
    "coverage/",
    ".env",
    "package.json",
    "package-lock.json",
    "npm-shrinkwrap.json",
    "app-vNext/package.json",
    "app-vNext/package-lock.json",
    "app-vNext/npm-shrinkwrap.json",
    "index.html",
    "assets/",
    "sw.js",
    "manifest.webmanifest"
  ],
  "blockedTerms": [
    "api key",
    "bearer token",
    "secret",
    "openai",
    "anthropic",
    "gemini",
    "firebase functions",
    "httpsCallable",
    "process.env",
    "import.meta.env"
  ],
  "buildDirectory": "app-vNext",
  "buildCommand": "npm.cmd run build"
}
