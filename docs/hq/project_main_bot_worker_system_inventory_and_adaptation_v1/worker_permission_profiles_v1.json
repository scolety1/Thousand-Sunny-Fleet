{
  "schema_version": "worker_permission_profiles_v1",
  "default_forbidden_actions": [
    "push",
    "merge",
    "deploy",
    "install_packages",
    "migration",
    "secrets",
    "privatelens",
    "proof_run",
    "all_fleet",
    "background_runner",
    "persistent_runner",
    "canonical_nwr_inspection",
    "canonical_nwr_mutation",
    "normal_nwr_packet_read",
    "product_repo_inspection",
    "product_repo_mutation",
    "api_bridge",
    "open_network_port",
    "credential_change",
    "app_wiring",
    "ranking_formula_source_truth_promotion",
    "hidden_sort",
    "recommendation_behavior"
  ],
  "roles": {
    "project_main_bot": {
      "role_name": "Project Main Bot",
      "allowed_reads": ["TSF control docs", "project registry", "mission packets", "status files", "preservation packets"],
      "allowed_writes": ["mission drafts", "routing notes", "TSF-local status artifacts"],
      "forbidden_actions": ["default_forbidden_actions"],
      "output_contract": "One bounded mission packet, routing decision, or TIM_REQUIRED packet.",
      "verifier_required": true,
      "may_spawn_workers": true,
      "may_commit_locally": true,
      "tim_required_for": ["restricted actions", "product direction ambiguity", "cross-lane expansion", "remote or API action"]
    },
    "translator_helper_bot": {
      "role_name": "Translator Helper Bot",
      "allowed_reads": ["Tim prompt", "quick mission", "work-order inbox", "project passport", "TSF control docs"],
      "allowed_writes": ["mission intent draft", "summary note", "question register"],
      "forbidden_actions": ["command execution", "treating prose as approval", "default_forbidden_actions"],
      "output_contract": "Mission intent with goal, scope, exclusions, stop conditions, and exact questions if needed.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": false,
      "tim_required_for": ["unresolvable product direction", "missing exact approval", "unclear project identity"]
    },
    "context_memory_steward": {
      "role_name": "Context / Memory Steward",
      "allowed_reads": ["project passports", "next-session cards", "status freshness index", "artifact index", "preservation packets"],
      "allowed_writes": ["context capsule", "freshness note", "do-not-rebuild register"],
      "forbidden_actions": ["source-truth promotion", "product repo mutation", "normal NWR packet read", "credential access"],
      "output_contract": "Freshness-scored context bundle with evidence and exclusions.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["product/private repo access", "conflicting source truth", "archived reactivation"]
    },
    "parallel_lane_coordinator": {
      "role_name": "Parallel Lane Coordinator",
      "allowed_reads": ["git status", "branch metadata", "worktree boundary records", "mission write scopes"],
      "allowed_writes": ["lane split plan", "collision matrix", "branch/worktree recommendation"],
      "forbidden_actions": ["creating worktrees", "deleting worktrees", "merge", "push", "rebase", "all_fleet", "background_runner"],
      "output_contract": "Lane plan with ownership, collision result, stop signs, and merge recommendation.",
      "verifier_required": true,
      "may_spawn_workers": true,
      "may_commit_locally": true,
      "tim_required_for": ["actual worktree creation or deletion", "merge", "push", "rebase", "conflicting scope"]
    },
    "organizer_worker": {
      "role_name": "Organizer Worker",
      "allowed_reads": ["TSF docs", "review packets", "status files", "artifact indexes"],
      "allowed_writes": ["TSF-local docs", "manifests", "indexes", "status summaries"],
      "forbidden_actions": ["product_repo_mutation", "canonical_nwr_mutation", "push", "merge", "deploy", "secrets"],
      "output_contract": "Sorted index, manifest, or checklist with source trace.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["deleting or moving user-owned work", "canonical mutation"]
    },
    "builder_worker": {
      "role_name": "Builder Worker",
      "allowed_reads": ["mission allowed_reads"],
      "allowed_writes": ["mission allowed_writes"],
      "forbidden_actions": ["outside allowed writes", "default_forbidden_actions"],
      "output_contract": "Changed files, validation evidence, and preservation handoff.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["scope expansion", "restricted action"]
    },
    "ui_builder_worker": {
      "role_name": "UI Builder Worker",
      "allowed_reads": ["TSF UI docs", "prototype files", "approved assets"],
      "allowed_writes": ["approved UI or prototype files"],
      "forbidden_actions": ["runtime command binding", "network ports", "product repo mutation", "auth", "deploy", "push", "merge"],
      "output_contract": "Static UI/prototype artifact with no command authority.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["real Operator Console wiring", "remote auth", "deployment", "product repo access"]
    },
    "ai_builder_worker": {
      "role_name": "AI Builder Worker",
      "allowed_reads": ["TSF prompt docs", "HQ adapter docs", "schemas"],
      "allowed_writes": ["prompt docs", "packet schemas", "fixtures"],
      "forbidden_actions": ["API calls", "credential creation", "model promotion", "source-truth promotion", "production ranking behavior"],
      "output_contract": "Prompt or schema artifact with non-authority and validation notes.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["API usage", "credentials", "production model behavior"]
    },
    "stats_data_worker": {
      "role_name": "Stats/Data Worker",
      "allowed_reads": ["approved review-only data", "scoped TSF/NWR packets"],
      "allowed_writes": ["review-only reports", "CSV artifacts", "validation artifacts"],
      "forbidden_actions": ["production rankings", "formula promotion", "source-truth promotion", "canonical NWR mutation", "normal NWR packet reads without approval"],
      "output_contract": "Review-only source trace, missingness, caveats, and blocked-use statement.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["source promotion", "production/model use", "canonical or normal NWR expansion"]
    },
    "tester_worker": {
      "role_name": "Tester Worker",
      "allowed_reads": ["allowed test files", "fixtures", "changed files"],
      "allowed_writes": ["allowed tests", "fixtures", "test reports"],
      "forbidden_actions": ["all_fleet", "proof_run", "install_packages", "migration", "product repo tests without approval", "background_runner"],
      "output_contract": "Test result report with commands, pass/fail, and failures.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["proof runs", "installs", "product repo tests", "broad fleet tests"]
    },
    "auditor_worker": {
      "role_name": "Auditor Worker",
      "allowed_reads": ["allowed diffs", "review packets", "validation output"],
      "allowed_writes": ["audit report", "risk register", "recommendation JSON"],
      "forbidden_actions": ["approval on Tim's behalf", "merge", "push", "product mutation"],
      "output_contract": "Findings-first audit with readiness recommendation and caveats.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": false,
      "tim_required_for": ["approving or executing restricted actions"]
    },
    "export_creator_worker": {
      "role_name": "Export Creator Worker",
      "allowed_reads": ["allowed artifacts", "manifests", "reports"],
      "allowed_writes": ["local output packet", "manifest", "summary"],
      "forbidden_actions": ["sending packages", "uploading packages", "external account changes", "secrets", "product mutation"],
      "output_contract": "Local export packet with manifest and no-authority confirmation.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["sending", "uploading", "external account changes", "private data publication"]
    },
    "researcher_source_tracer_worker": {
      "role_name": "Researcher / Source Tracer Worker",
      "allowed_reads": ["allowed TSF docs", "approved project materials", "registries", "scoped packets"],
      "allowed_writes": ["trace section", "source map", "do-not-rebuild register"],
      "forbidden_actions": ["forbidden cross-lane reads", "normal NWR packets without scope", "product repo access without approval"],
      "output_contract": "Existing-asset trace with classification and reuse decision.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["cross-lane expansion", "protected repo/source access"]
    },
    "verifier_worker": {
      "role_name": "Verifier Worker",
      "allowed_reads": ["mission packet", "worker result", "git status", "expected artifacts"],
      "allowed_writes": ["verifier result", "validation matrix"],
      "forbidden_actions": ["weakening checks", "approving future work", "product repo mutation"],
      "output_contract": "GREEN, YELLOW, RED, or TIM_REQUIRED verifier result with evidence.",
      "verifier_required": false,
      "may_spawn_workers": false,
      "may_commit_locally": false,
      "tim_required_for": ["forbidden reads", "product access"]
    },
    "refactor_worker": {
      "role_name": "Refactor Worker",
      "allowed_reads": ["mission allowed_reads"],
      "allowed_writes": ["mission allowed_writes"],
      "forbidden_actions": ["broad redesign", "hidden behavior change", "product mutation without approval", "push", "merge"],
      "output_contract": "Small diff, unchanged behavior statement, and tests.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["behavior changes", "broad scope", "product repos", "missing tests"]
    },
    "documentation_worker": {
      "role_name": "Documentation Worker",
      "allowed_reads": ["TSF docs", "review packets", "schemas"],
      "allowed_writes": ["TSF docs", "control-plane artifacts"],
      "forbidden_actions": ["evidence-as-authority", "product mutation", "push", "merge", "deploy"],
      "output_contract": "Doc artifact with inputs, status, exclusions, and non-authority statement.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["docs implying restricted-action approval or production authority"]
    },
    "release_preservation_worker": {
      "role_name": "Release / Preservation Worker",
      "allowed_reads": ["mission artifacts", "verifier results", "git metadata"],
      "allowed_writes": ["preservation packet", "status summary", "approval packet draft"],
      "forbidden_actions": ["push", "merge", "branch deletion", "deploy", "external publication without approval"],
      "output_contract": "Durable packet with manifest, final decision, and next action.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": true,
      "tim_required_for": ["push", "merge", "deploy", "branch cleanup", "external publication"]
    },
    "chatgpt_api_hq_escalation_judge": {
      "role_name": "ChatGPT/API HQ Escalation Judge",
      "allowed_reads": ["HQ escalation packet", "summarized evidence"],
      "allowed_writes": ["strategic decision JSON"],
      "forbidden_actions": ["API call without approval", "execution authority", "product mutation", "source-truth promotion"],
      "output_contract": "GREEN, YELLOW, RED, or TIM_REQUIRED strategic decision with allowed verdicts.",
      "verifier_required": true,
      "may_spawn_workers": false,
      "may_commit_locally": false,
      "tim_required_for": ["API call", "credentials", "source-truth/model/ranking promotion", "restricted action"]
    }
  }
}
