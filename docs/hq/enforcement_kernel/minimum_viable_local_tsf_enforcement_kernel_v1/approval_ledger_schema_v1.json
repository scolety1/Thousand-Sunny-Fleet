{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimum Viable Local TSF Approval Ledger V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ledger_id",
    "approvals"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "ledger_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "notes": {
      "type": "string",
      "maxLength": 1000
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "approval_id",
          "approved_by",
          "approved_at",
          "repo_path",
          "lane",
          "exact_action",
          "allowed_files_or_paths",
          "required_verifier",
          "notes"
        ],
        "properties": {
          "approval_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "approved_by": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "scope_limit": {
            "type": "string",
            "maxLength": 500
          },
          "repo_path": {
            "type": "string",
            "minLength": 1
          },
          "lane": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "worktree_path": {
            "type": "string",
            "minLength": 1
          },
          "exact_action": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "allowed_files_or_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "required_verifier": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "sample_fixture_only": {
            "type": "boolean"
          },
          "state": {
            "type": "string",
            "enum": ["ACTIVE", "REVOKED", "EXHAUSTED"]
          },
          "mission_id": {
            "type": ["string", "null"]
          },
          "usage_count": {
            "type": "integer",
            "minimum": 0
          },
          "max_uses": {
            "type": "integer",
            "minimum": 1
          },
          "reuse_policy": {
            "type": "string",
            "enum": ["SINGLE_USE", "MULTI_USE", "UNLIMITED"]
          },
          "request_id": {
            "type": "string",
            "pattern": "^timreq-[a-f0-9]{32}$"
          },
          "request_evidence_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "request_evidence_path": {
            "type": "string",
            "minLength": 1
          },
          "source_mission_revision": {
            "type": "integer",
            "minimum": 1
          },
          "authorized_mission_revision": {
            "type": "integer",
            "minimum": 2
          },
          "source_run_id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 200
          },
          "source_result_id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 200
          },
          "response_id": {
            "type": "string",
            "pattern": "^hq-response-[A-Za-z0-9-]{16,80}$"
          },
          "response_content_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "access_level": {
            "enum": ["READ_ONLY", "WORKSPACE_WRITE", "APPROVAL_REQUIRED", "EXACT_ELEVATED_ACTION", "CUSTOM"]
          },
          "network_policy": {
            "enum": ["PROHIBITED", "PUBLIC_READ_ONLY", "ALLOWLISTED", "APPROVAL_REQUIRED"]
          },
          "control_plane_service_network_policy": {
            "enum": ["NONE", "CODEX_SERVICE_ONLY"]
          },
          "worker_tool_network_policy": {
            "const": "DISABLED"
          },
          "surface": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "model": {
            "type": ["string", "null"],
            "maxLength": 160
          },
          "authority_not_included": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "maxLength": 120 }
          },
          "consumed_by_run_id": {
            "type": ["string", "null"],
            "maxLength": 200
          },
          "consumed_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "notes": {
            "type": "string",
            "maxLength": 1000
          }
        },
        "anyOf": [
          {
            "required": [
              "expires_at"
            ]
          },
          {
            "required": [
              "scope_limit"
            ]
          }
        ]
      }
    }
  }
}
