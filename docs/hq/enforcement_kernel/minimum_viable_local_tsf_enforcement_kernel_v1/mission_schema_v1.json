{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimum Viable Local TSF Mission Packet V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "project_id",
    "repo_path",
    "lane",
    "mission_type",
    "control_plane_service_network_policy",
    "worker_tool_network_policy",
    "allowed_reads",
    "allowed_writes",
    "forbidden_reads",
    "forbidden_writes",
    "forbidden_actions",
    "expected_artifacts",
    "required_preflight_checks",
    "required_postrun_checks",
    "stop_conditions",
    "approval_requirements",
    "hq_escalation_policy",
    "created_by",
    "created_at"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "MASTER_TSF_CONTROL_PLANE",
        "TSF_NWR",
        "NORMAL_NWR",
        "PRODUCT_REPO",
        "PRIVATE_LENS",
        "OTHER"
      ]
    },
    "mission_type": {
      "type": "string",
      "enum": [
        "tsf_infrastructure",
        "docs_control_plane",
        "review_only",
        "validation",
        "adapter",
        "null_fence",
        "admission_gate",
        "worker_handoff"
      ]
    },
    "required_branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "required_worktree": {
      "type": "string",
      "minLength": 1
    },
    "control_plane_service_network_policy": {
      "type": "string",
      "enum": ["NONE", "CODEX_SERVICE_ONLY"]
    },
    "worker_tool_network_policy": {
      "const": "DISABLED"
    },
    "allowed_reads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "allowed_writes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forbidden_reads": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forbidden_writes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "push",
          "merge",
          "deploy",
          "install_packages",
          "migration",
          "secrets",
          "privatelens",
          "proof_run",
          "all_fleet",
          "background_runner",
          "persistent_runner",
          "canonical_nwr_inspection",
          "canonical_nwr_mutation",
          "normal_nwr_packet_read",
          "product_repo_inspection",
          "product_repo_mutation",
          "api_bridge",
          "open_network_port",
          "credential_change",
          "app_wiring",
          "ranking_formula_source_truth_promotion",
          "hidden_sort",
          "recommendation_behavior"
        ]
      },
      "uniqueItems": true
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_preflight_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_postrun_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "check_type",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "check_type": {
            "type": "string",
            "enum": [
              "manual",
              "path_absent",
              "approval_required",
              "forbidden_action_absent",
              "artifact_exists",
              "git_status_captured"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    },
    "approval_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "exact_action",
          "required",
          "reason"
        ],
        "properties": {
          "exact_action": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "approval_id": {
            "type": "string",
            "maxLength": 120
          }
        }
      }
    },
    "hq_escalation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "escalate_on",
        "notes"
      ],
      "properties": {
        "default": {
          "type": "string",
          "enum": [
            "local_only_no_api",
            "hq_packet_required",
            "tim_required"
          ]
        },
        "escalate_on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "RED",
              "TIM_REQUIRED",
              "approval_gap",
              "scope_conflict",
              "protected_repo",
              "source_truth_promotion"
            ]
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
