{
  "schema_version": "mission_queue_foreground_executor_policy_v1",
  "default_posture": "fail_closed",
  "executor_mode": "foreground_only",
  "queue_root": "fleet/missions",
  "allowed_start_states": [
    "inbox",
    "drafted"
  ],
  "worker_running_requires_explicit_flag": true,
  "run_approved_fixture_worker_flag": "-RunApprovedFixtureWorker",
  "run_canonical_app_server_worker_flag": "-RunCanonicalAppServerWorker",
  "dry_run_flag": "-DryRun",
  "required_exact_action": "codex_cli_queue_fixture_worker_invocation",
  "allowed_fixture_output_root": "tests/fixtures/fleet/mission-queue/worker-output",
  "allowed_fixture_worker_roles": [
    "builder_worker",
    "tester_worker",
    "auditor_worker"
  ],
  "codex_command_shape": {
    "service_tier": "fast",
    "sandbox": "workspace-write",
    "normal_user_config": true,
    "ignore_user_config": false,
    "danger_full_access": false,
    "ephemeral": false,
    "json_events": true
  },
  "control_plane_service_network_policy": "CODEX_SERVICE_ONLY",
  "worker_tool_network_policy": "DISABLED",
  "forbidden_actions": [
    "push",
    "merge",
    "deploy",
    "install_packages",
    "migration",
    "secrets",
    "privatelens",
    "proof_run",
    "all_fleet",
    "background_runner",
    "persistent_runner",
    "canonical_nwr_inspection",
    "canonical_nwr_mutation",
    "normal_nwr_packet_read",
    "product_repo_inspection",
    "product_repo_mutation",
    "api_bridge",
    "open_network_port",
    "credential_change",
    "app_wiring",
    "ranking_formula_source_truth_promotion",
    "hidden_sort",
    "recommendation_behavior"
  ],
  "stop_conditions": [
    "unknown_queue_state",
    "invalid_state_transition",
    "missing_kernel_preflight_approval",
    "missing_role_permission_approval",
    "missing_exact_worker_approval",
    "worker_attempts_forbidden_path",
    "worker_budget_exceeded",
    "codex_cli_auth_or_execution_unclear",
    "verifier_red",
    "background_or_persistent_execution_requested"
  ]
}
