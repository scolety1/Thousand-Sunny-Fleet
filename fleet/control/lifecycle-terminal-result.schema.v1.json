{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsf://fleet/control/lifecycle-terminal-result.schema.v1.json",
  "title": "TSF Lifecycle Terminal Result V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "generated_at", "lifecycle_invoked", "terminal_status", "final_decision",
    "outcome_stage", "mission_id", "mission_revision", "run_id", "queue_document_sha256",
    "policy_fingerprint", "repository", "branch", "worktree", "result_path", "out_directory",
    "producer_registry_path", "producer_binding_identity_sha256", "orchestrator_invocation_identity",
    "mission_path", "effective_mission_path", "queue_mission_path", "queue_state",
    "preflight_verdict", "preflight_approved", "role_preflight_verdict", "role_preflight_required", "role_preflight_approved", "worker_launched", "worker_status",
    "verifier_verdict", "preservation_status", "preservation_packet_file", "preservation_packet_path",
    "preservation_manifest_path", "adapter_result_path", "worker_result_path",
    "verifier_result_path", "evidence_preserved", "runtime_path_maximum", "events",
    "blocked_reasons", "internal_error", "background_runner_started",
    "worker_tool_network_enabled", "push_merge_deploy_attempted"
  ],
  "properties": {
    "schema_version": { "const": "tsf_lifecycle_terminal_result_v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "lifecycle_invoked": { "const": true },
    "terminal_status": { "enum": ["COMPLETED_GREEN", "COMPLETED_WITH_CAVEATS", "BLOCKED_PREFLIGHT", "BLOCKED_ROLE_PERMISSION", "BLOCKED_WORKER_START", "BLOCKED_WORKER_RESULT", "BLOCKED_VERIFIER", "BLOCKED_PRESERVATION", "TIM_REQUIRED", "INTERNAL_ERROR"] },
    "final_decision": { "enum": ["GREEN", "YELLOW", "RED", "TIM_REQUIRED"] },
    "outcome_stage": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "mission_revision": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "queue_document_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "policy_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "repository": { "type": "string", "minLength": 1 },
    "branch": { "type": "string" },
    "worktree": { "type": "string", "minLength": 1 },
    "result_path": { "type": "string", "minLength": 1 },
    "out_directory": { "type": "string", "minLength": 1 },
    "producer_registry_path": { "type": "string", "minLength": 1 },
    "producer_binding_identity_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "orchestrator_invocation_identity": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "mission_path": { "type": "string" },
    "effective_mission_path": { "type": "string" },
    "queue_mission_path": { "type": "string" },
    "queue_state": { "type": "string" },
    "preflight_verdict": { "type": "string" },
    "preflight_approved": { "type": "boolean" },
    "role_preflight_verdict": { "type": "string" },
    "role_preflight_required": { "type": "boolean" },
    "role_preflight_approved": { "type": "boolean" },
    "worker_launched": { "type": "boolean" },
    "worker_status": { "type": "string" },
    "verifier_verdict": { "type": "string" },
    "preservation_status": { "enum": ["NOT_ATTEMPTED", "PRESERVED", "BLOCKED"] },
    "preservation_packet_file": { "type": "string" },
    "preservation_packet_path": { "type": "string" },
    "preservation_manifest_path": { "type": "string" },
    "adapter_result_path": { "type": "string" },
    "worker_result_path": { "type": "string" },
    "verifier_result_path": { "type": "string" },
    "evidence_preserved": { "type": "boolean" },
    "runtime_path_maximum": { "type": "integer", "minimum": 0 },
    "events": { "type": "array", "items": { "type": "object" } },
    "blocked_reasons": { "type": "array", "items": { "type": "string" } },
    "internal_error": { "type": "string" },
    "background_runner_started": { "const": false },
    "worker_tool_network_enabled": { "const": false },
    "push_merge_deploy_attempted": { "const": false }
  }
}
