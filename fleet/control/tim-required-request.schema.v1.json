{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsf://fleet/control/tim-required-request.schema.v1.json",
  "title": "TSF Canonical TIM_REQUIRED Request V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "request_id", "request_kind", "mission_id", "mission_revision",
    "run_id", "result_id", "repository", "worktree", "operation", "exact_paths",
    "access_level", "network_scope", "surface", "model", "reason", "question",
    "issued_at", "expires_at", "usage_limit", "response_types", "authority_not_included",
    "original_run_terminal", "worker_active", "app_server_child_active", "superseded",
    "invalidated"
  ],
  "properties": {
    "schema_version": { "const": "tsf_tim_required_request_v1" },
    "request_id": { "type": "string", "pattern": "^timreq-[a-f0-9]{32}$" },
    "request_kind": { "enum": ["APPROVAL_REQUIRED", "CLARIFICATION_REQUIRED", "AUTHORITY_DECISION_REQUIRED"] },
    "mission_id": { "type": "string", "minLength": 8, "maxLength": 160 },
    "mission_revision": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 8, "maxLength": 200 },
    "result_id": { "type": "string", "minLength": 8, "maxLength": 200 },
    "repository": { "type": "string", "minLength": 1 },
    "worktree": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9._:-]+$" },
    "exact_paths": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500, "not": { "pattern": "[?*]" } }
    },
    "access_level": { "enum": ["READ_ONLY", "WORKSPACE_WRITE", "APPROVAL_REQUIRED", "EXACT_ELEVATED_ACTION", "CUSTOM"] },
    "network_scope": {
      "type": "object", "additionalProperties": false,
      "required": ["mission_policy", "control_plane", "worker_tool"],
      "properties": {
        "mission_policy": { "enum": ["PROHIBITED", "PUBLIC_READ_ONLY", "ALLOWLISTED", "APPROVAL_REQUIRED"] },
        "control_plane": { "enum": ["NONE", "CODEX_SERVICE_ONLY"] },
        "worker_tool": { "const": "DISABLED" }
      }
    },
    "surface": { "type": "string", "minLength": 1, "maxLength": 80 },
    "model": { "type": ["string", "null"], "maxLength": 160 },
    "reason": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "question": { "type": ["string", "null"], "maxLength": 1000 },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "usage_limit": {
      "type": "object", "additionalProperties": false,
      "required": ["max_uses", "reuse_policy"],
      "properties": {
        "max_uses": { "const": 1 },
        "reuse_policy": { "const": "SINGLE_USE" }
      }
    },
    "response_types": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["APPROVE_EXACT_REQUEST", "DENY_REQUEST", "PROVIDE_CLARIFICATION"] }
    },
    "authority_not_included": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "original_run_terminal": { "const": true },
    "worker_active": { "const": false },
    "app_server_child_active": { "const": false },
    "superseded": { "type": "boolean" },
    "invalidated": { "type": "boolean" }
  }
}
