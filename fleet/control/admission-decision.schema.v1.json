{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsf://fleet/control/admission-decision.schema.v1.json",
  "title": "TSF Admission Decision Receipt V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "result_id", "mission_id", "mission_revision", "mission_content_hash", "policy_fingerprint", "result_validation_mode", "original_intent_identity_sha256", "scope_transformation_identity_sha256", "task_completion_contract_identity_sha256", "outcome_disposition", "queue_document_sha256", "translator_version", "preservation_packet_path", "preservation_packet_sha256", "queue_authority_kind", "queue_authority_root", "queue_authority_identity_sha256", "production_admission", "receipt_identity_sha256", "admission_decision_sha256", "admission_receipt_path", "transaction_receipt_path", "result_sha256", "status", "reasons", "caveats", "duplicate_submission", "idempotent_replay", "decided_at", "queue_state_from", "queue_state_to", "queue_transition_applied", "queue_transition_path", "grants_approval", "grants_merge_authority", "grants_production_authority"],
  "properties": {
    "schema_version": { "const": "tsf_admission_decision_v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "result_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": ["string", "null"] },
    "mission_revision": { "type": "integer", "minimum": 1 },
    "mission_content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "policy_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "result_validation_mode": { "enum": ["EXACT_LITERAL_V1", "GENERAL_RESULT_V2"] },
    "original_intent_identity_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "scope_transformation_identity_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "task_completion_contract_identity_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "outcome_disposition": { "type": ["string", "null"], "enum": ["FULFILLED", "FULFILLED_WITH_CAVEATS", "PARTIAL", "UNABLE_TO_PERFORM", "REFUSED", "BLOCKED_BY_POLICY", "NEEDS_CLARIFICATION", "REQUIRED_DELIVERABLE_MISSING", "WRONG_TASK_PERFORMED", "FAILED", "UNCLASSIFIED_RESULT", null] },
    "queue_document_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "translator_version": { "const": "tsf_durable_to_operational_v1" },
    "preservation_packet_path": { "type": "string", "minLength": 1 },
    "preservation_packet_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "queue_authority_kind": { "enum": ["PRODUCTION", "TEST_ONLY"] },
    "queue_authority_root": { "type": "string", "minLength": 1 },
    "queue_authority_identity_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "production_admission": { "type": "boolean" },
    "receipt_identity_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "admission_decision_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "admission_receipt_path": { "type": "string", "minLength": 1 },
    "transaction_receipt_path": { "type": "string", "minLength": 1 },
    "result_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "status": { "enum": ["ADMITTED", "ADMITTED_WITH_CAVEATS", "REVIEW_REQUIRED", "REJECTED_OUT_OF_SCOPE", "REJECTED_POLICY_MISMATCH", "REJECTED_INVALID_EVIDENCE", "UNTRUSTED_NOT_TSF_GOVERNED", "TIM_REQUIRED"] },
    "reasons": { "type": "array", "items": { "type": "string" } },
    "caveats": { "type": "array", "items": { "type": "string" } },
    "duplicate_submission": { "type": "boolean" },
    "idempotent_replay": { "type": "boolean" },
    "decided_at": { "type": "string", "format": "date-time" },
    "queue_state_from": { "const": "postrun_pending" },
    "queue_state_to": { "enum": ["complete_review_only", "complete_ready_for_gate", "blocked_needs_tim"] },
    "queue_transition_applied": { "type": "boolean" },
    "queue_transition_path": { "type": "string" },
    "grants_approval": { "const": false },
    "grants_merge_authority": { "const": false },
    "grants_production_authority": { "const": false }
  }
}
