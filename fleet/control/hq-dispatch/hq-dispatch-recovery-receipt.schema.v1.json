{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsf://fleet/control/hq-dispatch/hq-dispatch-recovery-receipt.schema.v1.json",
  "title": "TSF HQ Dispatch recovery audit receipt V1",
  "type": "object",
  "required": [
    "schema_version", "receipt_id", "recorded_at", "mission_id", "mission_revision", "run_id", "result_id",
    "source_classification", "source_evidence_hash", "source_paths", "action", "changes", "immutable",
    "grants_approval", "grants_merge_authority", "grants_deployment_authority", "grants_production_authority",
    "idempotency_identity_sha256"
  ],
  "properties": {
    "schema_version": { "const": "tsf_hq_dispatch_recovery_receipt_v1" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" },
    "mission_id": { "type": "string", "minLength": 8 },
    "mission_revision": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 8 },
    "result_id": { "type": "string", "minLength": 8 },
    "source_classification": { "type": "string", "minLength": 1 },
    "source_evidence_hash": { "$ref": "#/$defs/sha256" },
    "source_paths": { "type": "object" },
    "action": { "type": "string", "minLength": 1 },
    "changes": { "type": "string", "minLength": 1 },
    "immutable": { "type": "string", "minLength": 1 },
    "grants_approval": { "const": false },
    "grants_merge_authority": { "const": false },
    "grants_deployment_authority": { "const": false },
    "grants_production_authority": { "const": false },
    "idempotency_identity_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
}
