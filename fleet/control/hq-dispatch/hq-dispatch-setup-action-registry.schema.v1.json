{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tsf_hq_dispatch_setup_action_registry_schema_v1",
  "title": "TSF HQ Dispatch setup and action registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_on",
    "projection_posture",
    "sources",
    "actions"
  ],
  "properties": {
    "schema_version": {
      "const": "tsf_hq_dispatch_setup_action_registry_v1"
    },
    "generated_on": {
      "const": "2026-07-13"
    },
    "projection_posture": {
      "const": "MILESTONE_1_PREVIEW_ONLY"
    },
    "sources": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action_id",
          "label",
          "kind",
          "class",
          "source_path",
          "source_locator",
          "availability",
          "required_human_gate",
          "authority_boundary",
          "execution_enabled"
        ],
        "properties": {
          "action_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "service_operation",
              "console_action",
              "entrypoint"
            ]
          },
          "class": {
            "enum": [
              "safe",
              "caution",
              "approval-required",
              "future-only",
              "forbidden",
              "read_only_status",
              "fixture_only",
              "selected_ship_required",
              "selected_project_required",
              "external_review_request_only",
              "mobile_request_only",
              "legacy_broad_requires_human"
            ]
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "source_locator": {
            "type": "string",
            "minLength": 1
          },
          "availability": {
            "enum": [
              "AVAILABLE_PREVIEW_ONLY",
              "AVAILABLE_READ_ONLY",
              "PROJECTED_DISABLED_MILESTONE_1",
              "PROJECTED_APPROVAL_REQUIRED_DISABLED",
              "PROJECTED_FUTURE_ONLY_DISABLED",
              "NOT_AVAILABLE_FORBIDDEN",
              "REFERENCE_ONLY_DISABLED"
            ]
          },
          "required_human_gate": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "required",
              "gate"
            ],
            "properties": {
              "required": {
                "type": "boolean"
              },
              "gate": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "authority_boundary": {
            "type": "string",
            "minLength": 1
          },
          "execution_enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
