{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tsf_hq_dispatch_skill_registry_schema_v1",
  "title": "TSF HQ Dispatch skill registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_on",
    "projection_posture",
    "sources",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "const": "tsf_hq_dispatch_skill_registry_v1"
    },
    "generated_on": {
      "const": "2026-07-13"
    },
    "projection_posture": {
      "const": "STATIC_REGISTRY_PROJECTION_NOT_EXECUTION_AUTHORITY"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256",
          "source_kind"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "source_kind": {
            "enum": [
              "documented_skill_map",
              "local_skill_definition"
            ]
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skill_id",
          "presence",
          "documented_in_skill_map",
          "locally_present_definition",
          "source_paths",
          "phase_mappings"
        ],
        "properties": {
          "skill_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "presence": {
            "enum": [
              "DOCUMENTED_AND_LOCAL_DEFINITION",
              "DOCUMENTED_ONLY"
            ]
          },
          "documented_in_skill_map": {
            "const": true
          },
          "locally_present_definition": {
            "type": "boolean"
          },
          "source_paths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "phase_mappings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
