{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"tsf://fleet/control/task-completion-contract.schema.v1.json","title":"TSF Task Completion Contract V1","type":"object","additionalProperties":false,
  "required":["schema_version","contract_version","required_task","required_task_sha256","required_deliverables","required_output_format","required_evidence","optional_deliverables","partial_completion_allowed","accepted_dispositions","success_criteria","fail_closed_conditions","original_intent_identity_sha256","scope_transformation_identity_sha256","task_completion_contract_identity_sha256"],
  "properties":{
    "schema_version":{"const":"tsf_task_completion_contract_v1"},"contract_version":{"const":"TASK_COMPLETION_CONTRACT_V1"},"required_task":{"type":"string","minLength":1,"maxLength":4000},"required_task_sha256":{"$ref":"#/$defs/sha256"},
    "required_deliverables":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["deliverable_id","description","evidence_rule"],"properties":{"deliverable_id":{"type":"string","pattern":"^[a-z][a-z0-9_]{2,63}$"},"description":{"type":"string","minLength":1},"evidence_rule":{"const":"NONEMPTY_SUBSTANTIVE_TEXT_V1"}}}},
    "required_output_format":{"const":"TSF_GENERAL_RESULT_V2_JSON"},"required_evidence":{"$ref":"#/$defs/nonEmptyStringArray"},"optional_deliverables":{"$ref":"#/$defs/stringArray"},"partial_completion_allowed":{"type":"boolean"},
    "accepted_dispositions":{"type":"array","minItems":1,"items":{"enum":["FULFILLED","FULFILLED_WITH_CAVEATS","PARTIAL"]},"uniqueItems":true},"success_criteria":{"$ref":"#/$defs/nonEmptyStringArray"},"fail_closed_conditions":{"$ref":"#/$defs/nonEmptyStringArray"},
    "original_intent_identity_sha256":{"$ref":"#/$defs/sha256"},"scope_transformation_identity_sha256":{"$ref":"#/$defs/sha256"},"task_completion_contract_identity_sha256":{"$ref":"#/$defs/sha256"}
  },"$defs":{"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},"stringArray":{"type":"array","items":{"type":"string","minLength":1},"uniqueItems":true},"nonEmptyStringArray":{"type":"array","minItems":1,"items":{"type":"string","minLength":1},"uniqueItems":true}}
}
