{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsf://fleet/control/result-envelope.schema.v1.json",
  "title": "TSF Durable Result Envelope V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "result_id", "mission_id", "mission_revision", "mission_content_hash", "parent_mission_id", "policy_fingerprint",
    "surface_used", "surface_task_identity", "actual_model", "actual_reasoning_effort", "model_assurance_level", "effort_evidence",
    "actual_repository", "actual_branch_worktree", "git_facts", "files_inspected", "files_changed",
    "major_actions", "network_activity", "artifacts", "tests", "verifier_evidence", "approval_use", "preservation_evidence", "evidence_bindings",
    "deviations_from_mission", "uncertainty", "security_or_scope_warnings", "proposed_next_action",
    "authority_statement", "grants_approval", "grants_merge_authority", "grants_production_authority", "created_at"
  ],
  "properties": {
    "schema_version": { "const": "tsf_result_envelope_v1" },
    "result_id": { "type": "string", "minLength": 8, "maxLength": 160, "pattern": "^[A-Za-z0-9._:-]+$" },
    "mission_id": { "type": ["string", "null"] },
    "mission_revision": { "type": "integer", "minimum": 1 },
    "mission_content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "parent_mission_id": { "type": ["string", "null"] },
    "policy_fingerprint": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "surface_used": { "type": "string", "minLength": 1 },
    "surface_task_identity": { "type": ["string", "null"] },
    "actual_model": { "type": ["string", "null"] },
    "actual_reasoning_effort": { "enum": ["UNKNOWN", "LIGHT", "MEDIUM", "HIGH", "EXTRA_HIGH", "MAX", "ULTRA"] },
    "model_assurance_level": { "enum": ["RECOMMENDED_ONLY", "USER_CONFIRMED", "ADAPTER_VERIFIED", "TECHNICALLY_ENFORCED"] },
    "effort_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "normalization_vocabulary", "mission_requested_effort", "canonical_resolved_effort",
        "thread_default_effort", "turn_requested_effort", "effective_effort", "effective_effort_raw",
        "effective_effort_source", "effort_assurance", "required_effort_assurance",
        "turn_request_acknowledged", "native_reroute_or_override_events", "effort_conflicts",
        "effort_admission_effect"
      ],
      "properties": {
        "normalization_vocabulary": { "const": "tsf_canonical_effort_v1" },
        "mission_requested_effort": { "type": "string", "minLength": 1 },
        "canonical_resolved_effort": { "$ref": "#/$defs/canonicalEffort" },
        "thread_default_effort": { "type": ["string", "null"] },
        "turn_requested_effort": { "type": ["string", "null"] },
        "effective_effort": { "$ref": "#/$defs/canonicalEffort" },
        "effective_effort_raw": { "type": ["string", "null"] },
        "effective_effort_source": { "enum": ["NOT_EXPOSED", "THREAD_SETTINGS_UPDATED", "TURN_COMPLETION", "TECHNICALLY_ENFORCED"] },
        "effort_assurance": { "enum": ["RECOMMENDED_ONLY", "ADAPTER_VERIFIED", "TECHNICALLY_ENFORCED"] },
        "required_effort_assurance": { "enum": ["RECOMMENDED_ONLY", "USER_CONFIRMED", "ADAPTER_VERIFIED", "TECHNICALLY_ENFORCED"] },
        "turn_request_acknowledged": { "type": "boolean" },
        "native_reroute_or_override_events": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["method", "sequence", "thread_id", "turn_id", "raw_payload_json", "raw_payload_sha256"],
            "properties": {
              "method": { "enum": ["thread/settings/updated", "model/rerouted"] },
              "sequence": { "type": "integer", "minimum": 1 },
              "thread_id": { "type": ["string", "null"] },
              "turn_id": { "type": ["string", "null"] },
              "raw_payload_json": { "type": "string", "minLength": 2 },
              "raw_payload_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "effort_conflicts": { "$ref": "#/$defs/stringArray" },
        "effort_admission_effect": { "enum": ["ADMITTED", "ADMITTED_WITH_CAVEATS", "REVIEW_REQUIRED", "REJECTED_OUT_OF_SCOPE", "REJECTED_INVALID_EVIDENCE", "TIM_REQUIRED"] }
      }
    },
    "usage_evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "evidence_classification", "source_method", "selected_sequence", "raw_payload_sha256", "event_count", "unique_event_count", "total_tokens", "input_tokens", "cached_input_tokens", "output_tokens", "reasoning_output_tokens", "model_context_window"],
      "properties": {
        "status": { "enum": ["OBSERVED", "NOT_EXPOSED"] },
        "evidence_classification": { "$ref": "#/$defs/evidenceClass" },
        "source_method": { "enum": ["thread/tokenUsage/updated", "NOT_EXPOSED"] },
        "selected_sequence": { "type": ["integer", "null"], "minimum": 1 },
        "raw_payload_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "event_count": { "type": "integer", "minimum": 0 },
        "unique_event_count": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cached_input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "reasoning_output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "model_context_window": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "actual_repository": { "type": ["string", "null"] },
    "actual_branch_worktree": {
      "type": "object", "additionalProperties": false, "required": ["branch", "worktree"],
      "properties": { "branch": { "type": ["string", "null"] }, "worktree": { "type": ["string", "null"] } }
    },
    "git_facts": {
      "type": "object", "additionalProperties": false, "required": ["starting_head", "ending_head", "base_head", "dirty_before", "dirty_after"],
      "properties": {
        "starting_head": { "type": ["string", "null"] }, "ending_head": { "type": ["string", "null"] },
        "base_head": { "type": ["string", "null"] }, "dirty_before": { "type": ["boolean", "null"] }, "dirty_after": { "type": ["boolean", "null"] }
      }
    },
    "files_inspected": { "$ref": "#/$defs/stringArray" },
    "files_changed": { "$ref": "#/$defs/stringArray" },
    "major_actions": { "$ref": "#/$defs/stringArray" },
    "network_activity": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "used", "destinations", "control_plane_service_network_policy", "worker_tool_network_policy", "codex_service_connection_used", "direct_openai_api_called_by_tsf", "external_api_called", "worker_network_used"],
      "properties": {
        "status": { "enum": ["UNKNOWN", "NONE_OBSERVED", "DECLARED", "ADAPTER_VERIFIED"] },
        "used": { "type": ["boolean", "null"] },
        "destinations": { "$ref": "#/$defs/stringArray" },
        "control_plane_service_network_policy": { "enum": ["NONE", "CODEX_SERVICE_ONLY"] },
        "worker_tool_network_policy": { "const": "DISABLED" },
        "codex_service_connection_used": { "type": "boolean" },
        "direct_openai_api_called_by_tsf": { "const": false },
        "external_api_called": { "const": false },
        "worker_network_used": { "const": false }
      }
    },
    "artifacts": {
      "type": "array", "items": {
        "type": "object", "additionalProperties": false, "required": ["path", "sha256", "exists", "evidence_classification"],
        "properties": { "path": { "type": "string", "minLength": 1 }, "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }, "exists": { "type": "boolean" }, "evidence_classification": { "$ref": "#/$defs/evidenceClass" } }
      }
    },
    "tests": {
      "type": "array", "items": {
        "type": "object", "additionalProperties": false, "required": ["test_id", "status", "observed", "evidence", "evidence_classification"],
        "properties": {
          "test_id": { "type": "string", "minLength": 1 }, "status": { "enum": ["PASS", "FAIL", "NOT_RUN", "UNKNOWN"] },
          "observed": { "type": "string" }, "evidence": { "type": ["string", "null"] }, "evidence_classification": { "$ref": "#/$defs/evidenceClass" }
        }
      }
    },
    "verifier_evidence": {
      "type": "array", "items": {
        "type": "object", "additionalProperties": false, "required": ["verifier_id", "verifier_role", "independence", "passed", "evidence", "evidence_classification"],
        "properties": {
          "verifier_id": { "type": "string", "minLength": 1 },
          "verifier_role": { "type": "string", "minLength": 1 },
          "independence": { "enum": ["NONE", "SEPARATE_TASK", "SEPARATE_ROLE", "INDEPENDENT_HUMAN"] },
          "passed": { "type": "boolean" }, "evidence": { "type": ["string", "null"] }, "evidence_classification": { "$ref": "#/$defs/evidenceClass" }
        }
      }
    },
    "approval_use": {
      "type": "array", "items": {
        "type": "object", "additionalProperties": false, "required": ["approval_id", "exact_action", "used", "evidence_classification"],
        "properties": { "approval_id": { "type": "string", "minLength": 1 }, "exact_action": { "type": "string", "minLength": 1 }, "used": { "type": "boolean" }, "evidence_classification": { "$ref": "#/$defs/evidenceClass" } }
      }
    },
    "preservation_evidence": {
      "type": "object", "additionalProperties": false, "required": ["packet_path", "packet_sha256", "evidence_classification"],
      "properties": { "packet_path": { "type": "string", "minLength": 1 }, "packet_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "evidence_classification": { "$ref": "#/$defs/evidenceClass" } }
    },
    "evidence_bindings": {
      "type": "object", "additionalProperties": false,
      "required": ["mapper_version", "runtime_evidence_sha256", "repository", "git", "model", "effort", "files", "native", "adapter", "kernel", "verifier", "preservation"],
      "properties": { "mapper_version": { "const": "tsf_runtime_evidence_to_result_v1" }, "runtime_evidence_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "repository": { "$ref": "#/$defs/evidenceClass" }, "git": { "$ref": "#/$defs/evidenceClass" }, "model": { "$ref": "#/$defs/evidenceClass" }, "effort": { "$ref": "#/$defs/evidenceClass" }, "usage": { "$ref": "#/$defs/evidenceClass" }, "files": { "$ref": "#/$defs/evidenceClass" }, "native": { "$ref": "#/$defs/evidenceClass" }, "adapter": { "$ref": "#/$defs/evidenceClass" }, "kernel": { "$ref": "#/$defs/evidenceClass" }, "verifier": { "$ref": "#/$defs/evidenceClass" }, "preservation": { "$ref": "#/$defs/evidenceClass" } }
    },
    "deviations_from_mission": { "$ref": "#/$defs/stringArray" },
    "uncertainty": { "$ref": "#/$defs/stringArray" },
    "security_or_scope_warnings": { "$ref": "#/$defs/stringArray" },
    "proposed_next_action": { "type": "string", "minLength": 1 },
    "authority_statement": { "type": "string", "minLength": 1 },
    "grants_approval": { "type": "boolean", "default": false },
    "grants_merge_authority": { "type": "boolean", "default": false },
    "grants_production_authority": { "type": "boolean", "default": false },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "stringArray": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "canonicalEffort": { "enum": ["UNKNOWN", "LIGHT", "MEDIUM", "HIGH", "EXTRA_HIGH", "MAX", "ULTRA"] },
    "evidenceClass": { "enum": ["NATIVE_OBSERVED", "ADAPTER_OBSERVED", "KERNEL_OBSERVED", "FILESYSTEM_OBSERVED", "VERIFIER_OBSERVED", "AGENT_REPORTED", "UNVERIFIED"] }
  }
}
