{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TSF Parallel Lane Plan V1",
  "type": "object",
  "required": [
    "schema_version",
    "require_true_lanes",
    "lanes",
    "requested_actions"
  ],
  "properties": {
    "schema_version": { "const": "parallel_lane_plan_v1" },
    "require_true_lanes": { "type": "boolean" },
    "requested_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "lane_id",
          "codex_agent_id",
          "branch",
          "worktree_path",
          "owned_files"
        ],
        "properties": {
          "lane_id": { "type": "string" },
          "codex_agent_id": { "type": "string" },
          "branch": { "type": "string" },
          "worktree_path": { "type": "string" },
          "owned_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "checkpoint_policy": { "type": "string" },
          "merge_recommendation_rule": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
