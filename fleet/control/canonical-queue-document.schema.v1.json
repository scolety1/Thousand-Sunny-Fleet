{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsf://fleet/control/canonical-queue-document.schema.v1.json",
  "title": "TSF Canonical Durable Queue Document V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "compatibility_status", "durable_mission", "source_binding",
    "model_resolution", "mission_packet", "role_extension", "worker_instruction_packet"
  ],
  "properties": {
    "schema_version": { "const": "tsf_canonical_queue_document_v1" },
    "compatibility_status": { "const": "GENERATED_EXECUTION_PACKET" },
    "durable_mission": { "type": "object" },
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "durable_mission_id", "durable_mission_revision", "policy_fingerprint",
        "durable_mission_content_hash", "translator_version", "generated_at",
        "mission_packet_sha256", "role_extension_sha256", "worker_instruction_sha256",
        "expected_repository", "expected_branch", "expected_worktree", "expected_role"
      ],
      "properties": {
        "durable_mission_id": { "type": "string", "minLength": 8 },
        "durable_mission_revision": { "type": "integer", "minimum": 1 },
        "policy_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "durable_mission_content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "translator_version": { "const": "tsf_durable_to_operational_v1" },
        "generated_at": { "type": "string", "format": "date-time" },
        "mission_packet_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "role_extension_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "worker_instruction_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "exact_response_contract_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "original_intent_identity_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "scope_transformation_identity_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "task_completion_contract_identity_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "expected_repository": { "type": "string", "minLength": 1 },
        "expected_branch": { "type": ["string", "null"] },
        "expected_worktree": { "type": ["string", "null"] },
        "expected_role": { "type": "string", "minLength": 1 }
        ,"expected_permission_mode": { "enum": ["READ_ONLY", "WORKSPACE_WRITE", "APPROVAL_REQUIRED", "EXACT_ELEVATED_ACTION", "CUSTOM"] }
        ,"expected_network_policy": { "enum": ["PROHIBITED", "PUBLIC_READ_ONLY", "ALLOWLISTED", "APPROVAL_REQUIRED"] }
        ,"expected_control_plane_service_network_policy": { "enum": ["NONE", "CODEX_SERVICE_ONLY"] }
        ,"expected_worker_tool_network_policy": { "const": "DISABLED" }
        ,"expected_surface": { "type": "string", "minLength": 1 }
        ,"expected_model": { "type": ["string", "null"] }
      }
    },
    "model_resolution": { "type": "object" },
    "mission_packet": { "type": "object" },
    "role_extension": { "type": "object" },
    "worker_instruction_packet": { "type": "object" }
  }
}
